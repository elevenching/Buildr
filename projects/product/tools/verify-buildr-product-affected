#!/usr/bin/env bash
set -euo pipefail

product_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PATH="$product_root/node_modules/.bin:$PATH"

usage() {
  cat <<'EOF'
Usage: tools/verify-buildr-product-affected <group> [group...]

Groups:
  public    Public metadata, bilingual README, and npm tarball inventory
  cli       CLI architecture, compatibility, package parity, and runtime adapters
  package   Package assets, managed mutations, and managed data integrity
  openspec  OpenSpec fixtures, candidate audit, spec quality, and strict validation
  release   Public candidate and packed release lifecycle

The affected check always runs the fast verification once and de-duplicates shared
steps. Final candidates must still run npm run test:candidate.
EOF
}

if [[ "$#" -eq 0 ]]; then
  usage >&2
  exit 2
fi

cd "$product_root"
npm run test:fast

seen_steps=" "
run_once() {
  local step_id="$1"
  shift
  case "$seen_steps" in
    *" $step_id "*) return 0 ;;
  esac
  seen_steps="$seen_steps$step_id "
  printf '\n[verify-affected] %s\n' "$step_id"
  "$@"
}

for group in "$@"; do
  case "$group" in
    public)
      run_once open-source-candidate node tools/verification/release/open-source-candidate.mjs
      ;;
    cli)
      run_once cli-compatibility node tools/verification/cli/compatibility.mjs
      run_once cli-package-parity node tools/verification/cli/package-parity.mjs
      run_once runtime-adapter-parity node tools/verification/runtime/adapter-parity.mjs
      ;;
    package)
      run_once package-check ./buildr package check
      run_once managed-mutations node tools/verification/integrity/managed-mutations.mjs
      run_once managed-data-integrity node tools/verification/integrity/managed-data-integrity.mjs
      ;;
    openspec)
      run_once openspec-contract node tools/verification/openspec/contract.mjs
      run_once openspec-contract-audit node tools/verification/openspec/contract-audit.mjs
      ;;
    release)
      run_once open-source-candidate node tools/verification/release/open-source-candidate.mjs
      run_once release-smoke node tools/verification/release/release-smoke.mjs
      ;;
    *)
      echo "Unknown affected verification group: $group" >&2
      usage >&2
      exit 2
      ;;
  esac
done

echo "Buildr affected verification passed: $*"
