#!/usr/bin/env bash
set -euo pipefail

product_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
timing_file="$(mktemp)"
mvp_timing_file="$(mktemp)"
timing_output="${BUILDR_TIMING_OUTPUT:-${TMPDIR:-/tmp}/buildr-product-verification-timing.json}"
total_started_at="$(node -e 'process.stdout.write(String(Date.now()))')"

cleanup() {
  rm -f "$timing_file" "$mvp_timing_file"
}
trap cleanup EXIT

run_step() {
  local label="$1"
  shift
  local started_at finished_at duration_ms status
  printf '\n[verify-product] %s\n' "$label"
  started_at="$(node -e 'process.stdout.write(String(Date.now()))')"
  if "$@"; then
    status=0
  else
    status=$?
  fi
  finished_at="$(node -e 'process.stdout.write(String(Date.now()))')"
  duration_ms="$((finished_at - started_at))"
  if [[ "$status" -eq 0 ]]; then
    printf '%s\tpassed\t0\t%s\n' "$label" "$duration_ms" >> "$timing_file"
    printf '[verify-product] completed: %s (%s ms)\n' "$label" "$duration_ms"
  else
    printf '%s\tfailed\t%s\t%s\n' "$label" "$status" "$duration_ms" >> "$timing_file"
    node tools/verification/timing/report.mjs "$timing_file" "$timing_output" failed "$((finished_at - total_started_at))" "$mvp_timing_file"
    return "$status"
  fi
}

cd "$product_root"

run_step "fine-grained unit tests" npm run test:unit

run_step "open-source candidate" node tools/verification/release/open-source-candidate.mjs

run_step "repository onboarding from a clean checkout" node tools/verification/onboarding/repository.mjs

run_step "single-command init onboarding" node tools/verification/onboarding/init.mjs

run_step "package check" ./buildr package check

run_step "CLI modular architecture" node tools/verification/cli/architecture.mjs
run_step "CLI compatibility" node tools/verification/cli/compatibility.mjs
run_step "CLI package parity" node tools/verification/cli/package-parity.mjs

run_step "runtime adapter contract" node tools/verification/runtime/adapter-contract.mjs
run_step "runtime adapter parity" node tools/verification/runtime/adapter-parity.mjs

run_step "Service branch contract" node tools/verification/onboarding/service-branch.mjs

run_step "remote Skill timeout contract" node tools/verification/network/remote-text.mjs

BUILDR_MVP_TIMING_FILE="$mvp_timing_file" run_step "temporary workspace end-to-end" tools/verify-buildr-product-mvp

run_step "release tarball smoke" node tools/verification/release/release-smoke.mjs

run_step "managed mutations" node tools/verification/integrity/managed-mutations.mjs
run_step "managed data integrity" node tools/verification/integrity/managed-data-integrity.mjs

run_step "OpenSpec contract fixtures" node tools/verification/openspec/contract.mjs

run_step "OpenSpec contract candidate audit" node tools/verification/openspec/contract-audit.mjs

run_step "OpenSpec canonical spec quality" node tools/verification/openspec/spec-quality.mjs

run_step "openspec strict validation" openspec validate --all --strict

total_finished_at="$(node -e 'process.stdout.write(String(Date.now()))')"
node tools/verification/timing/report.mjs "$timing_file" "$timing_output" passed "$((total_finished_at - total_started_at))" "$mvp_timing_file"

printf '\nBuildr product verification passed.\n'
