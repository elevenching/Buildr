#!/usr/bin/env bash
set -euo pipefail

product_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source_bin="$product_root/tools/buildr"
install_dir="${BUILDR_CLI_INSTALL_DIR:-$HOME/.local/bin}"
target_bin="$install_dir/buildr"

if ! command -v node >/dev/null 2>&1; then
  echo "Buildr requires Node.js 20 or newer." >&2
  exit 1
fi

node_major="$(node -p 'Number(process.versions.node.split(".")[0])')"
if [[ "$node_major" -lt 20 ]]; then
  echo "Buildr requires Node.js 20 or newer; current version: $(node --version)" >&2
  exit 1
fi

if ! (cd "$product_root" && node --input-type=module -e "import('yaml')" >/dev/null 2>&1); then
  if ! command -v npm >/dev/null 2>&1; then
    echo "Buildr runtime dependencies are missing and npm is unavailable." >&2
    exit 1
  fi
  echo "Preparing Buildr runtime dependencies from package-lock.json..."
  (cd "$product_root" && npm ci --omit=dev)
fi

if [[ ! -x "$source_bin" ]]; then
  echo "Buildr CLI source is not executable: $source_bin" >&2
  exit 1
fi

mkdir -p "$install_dir"

if [[ -e "$target_bin" || -L "$target_bin" ]]; then
  existing_target="$(readlink "$target_bin" 2>/dev/null || true)"
  if [[ "$existing_target" != "$source_bin" ]]; then
    managed_buildr=false
    if [[ -L "$target_bin" && -n "$existing_target" ]]; then
      if [[ "$existing_target" != /* ]]; then
        existing_target="$install_dir/$existing_target"
      fi
      existing_product_root="$(cd "$(dirname "$existing_target")/.." 2>/dev/null && pwd || true)"
      if [[ -n "$existing_product_root" ]] && grep -Eq '"name"[[:space:]]*:[[:space:]]*"(@buildr-ai/buildr|@buildr/cli)"' "$existing_product_root/package.json" 2>/dev/null; then
        managed_buildr=true
      fi
    fi
    if [[ "$managed_buildr" != true ]]; then
      echo "Refusing to overwrite existing buildr command: $target_bin" >&2
      echo "Remove it first, or set BUILDR_CLI_INSTALL_DIR to another directory." >&2
      exit 1
    fi
  fi
fi

ln -sfn "$source_bin" "$target_bin"

echo "Installed buildr -> $source_bin"

case ":$PATH:" in
  *":$install_dir:"*)
    echo "buildr is available on PATH."
    ;;
  *)
    echo "$install_dir is not on PATH. Add it to your shell config, for example:"
    echo "  export PATH=\"$install_dir:\$PATH\""
    ;;
esac
